    "loanInfo": {
      "title": "Loan Amount",
      "body": "<p>The principal — the amount the bank lends you. Does not include down payment, insurance or fees.</p><p style=\"margin-top:9px;\">Typical down payment: <strong>10–30%</strong>. Below 20% the bank may require PMI/LMI.</p><div class=\"modal-links\"><span class=\"modal-links-title\">Learn more:</span><a href=\"https://www.investopedia.com/terms/p/principal.asp\" target=\"_blank\">Principal (Investopedia)</a></div>"
    },
    "propInfo": {
      "title": "Property",
      "body": "<p>Enter the property price and down payment — the calculator will compute the loan amount automatically.</p><p style=\"margin-top:9px;\"><strong>LTV (Loan-to-Value)</strong> = Loan / Price. Banks prefer LTV ≤ 80%.</p><div class=\"modal-links\"><span class=\"modal-links-title\">Learn more:</span><a href=\"https://www.investopedia.com/terms/l/loantovalue.asp\" target=\"_blank\">LTV Ratio</a></div>"
    },
    "rateTypeInfo": {
      "title": "Rate Type",
      "body": "<p><strong>Fixed</strong> — stays the same for the entire term. <strong>Fixed + Index</strong> — market index (EURIBOR/SOFR) + fixed bank spread.</p>"
    },
    "fixedRateInfo": {
      "title": "Interest Rate",
      "body": "<p><strong>Nominal annual rate</strong> from the contract. Monthly rate = Rate / 12.</p><p style=\"margin-top:9px;\">Annuity formula:<br><code>PMT = P × r / (1 − (1+r)^−n)</code></p>"
    },
    "payTypeInfo": {
      "title": "Payment Type",
      "body": "<p><strong>Annuity</strong> — equal payments throughout. <strong>Differentiated</strong> — principal split equally, interest decreasing.</p>"
    },
    "indexInfo": {
      "title": "EURIBOR / SOFR Index",
      "body": "<p><strong>EURIBOR</strong> — EU interbank rate. <strong>SOFR</strong> — US benchmark (NY Fed).</p>"
    },
    "indexRateInfo": {
      "title": "Index Value",
      "body": "<p>Loaded automatically from ECB Data API and NY Fed API.</p>"
    },
    "spreadInfo": {
      "title": "Bank Spread",
      "body": "<p><strong>Spread</strong> — fixed bank markup over the index. <code>Rate = Index + Spread</code></p>"
    },
    "earlyPayInfo": {
      "title": "Early Payment",
      "body": "<p>Extra payment above schedule. <strong>↓ Term</strong> — max savings. <strong>↓ Payment</strong> — reduced burden.</p>"
    },
    "indexChangeInfo": {
      "title": "Index Changes",
      "body": "<p>Model projected EURIBOR/SOFR changes by month.</p>"
